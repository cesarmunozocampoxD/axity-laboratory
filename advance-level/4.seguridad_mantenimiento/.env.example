APP_NAME=seguridad-mantenimiento
DEBUG=false
PORT=8000

# Connection strings — use a real URL in production
DATABASE_URL=sqlite:///./app.db

# Replace with a real secret; rotate regularly
API_KEY=replace-with-a-strong-random-key
